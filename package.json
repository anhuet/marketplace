{
  "name": "marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "resolutions": {
    "@types/express": "4.17.25",
    "@types/multer": "1.4.13",
    "typescript": "5.3.3",
    "@smithy/types": "^4.0.0",
    "@smithy/middleware-stack": "^4.0.0",
    "@smithy/protocol-http": "^4.0.0",
    "@smithy/smithy-client": "^4.0.0"
  },
  "scripts": {
    "postinstall": "bash scripts/fix-hoisting.sh",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "node_modules/.bin/tsc --noEmit -p tsconfig.base.json && yarn workspaces run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.0",
    "typescript": "~5.3.3"
  }
}
